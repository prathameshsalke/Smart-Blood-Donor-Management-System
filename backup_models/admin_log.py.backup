"""
Admin Log Model for tracking admin activities
"""

from app import db
from datetime import datetime

class AdminLog(db.Model):
    """Admin activity log model"""
    __tablename__ = 'admin_logs'
    
    id = db.Column(db.Integer, primary_key=True)
    admin_id = db.Column(db.Integer, db.ForeignKey('users.id'), nullable=False)
    admin_email = db.Column(db.String(120), nullable=False)
    
    action = db.Column(db.String(50), nullable=False)
    entity_type = db.Column(db.String(50), nullable=False)
    entity_id = db.Column(db.String(50))
    
    description = db.Column(db.Text)
    ip_address = db.Column(db.String(45))
    
    # Details
    old_values = db.Column(db.Text)
    new_values = db.Column(db.Text)
    
    # Timestamp
    created_at = db.Column(db.DateTime, default=datetime.utcnow)
    
    # Relationship - Updated to match new backref name
    admin = db.relationship('User', backref='admin_log_entries')  # Changed backref
    
    def to_dict(self):
        """Convert to dictionary"""
        return {
            'id': self.id,
            'admin': self.admin_email,
            'action': self.action,
            'entity': self.entity_type,
            'description': self.description,
            'ip': self.ip_address,
            'time': self.created_at.isoformat()
        }
    
    def __repr__(self):
        return f'<AdminLog {self.action} {self.entity_type} by {self.admin_email}>'